# ============================================
# Text2SQL Application Configuration
# ============================================

# ---- LLM Configuration ----
# Provider: "gemini", "openai", or "company"
LLM_PROVIDER=gemini

# Model name (provider-specific):
# - Gemini: gemini-2.0-flash, gemini-1.5-flash, gemini-1.5-pro
# - OpenAI: gpt-4o-mini, gpt-4o, gpt-3.5-turbo
# - Company: Gauss2.3, Gauss2.3 Think, GaussO Flash, GaussO Flash (S), GaussO4, GaussO4 Thinking
LLM_MODEL=gemini-2.0-flash

# Temperature (0 = deterministic, 1 = creative)
LLM_TEMPERATURE=0

# ---- API Keys ----
# For Google Gemini (get from https://aistudio.google.com/apikey)
GOOGLE_API_KEY=your-google-api-key-here

# For OpenAI
OPENAI_API_KEY=your-openai-api-key-here

# ---- Company LLM Configuration ----
# API key for company LLM
COMPANY_LLM_API_KEY=your-company-api-key-here

# Custom model ID (optional, for custom endpoints)
COMPANY_LLM_MODEL_ID=

# Custom model URL (optional, for custom endpoints)
COMPANY_LLM_MODEL_URL=

# ---- Database Configuration ----
DB_PATH=./database/text2sql.db
TABLE_NAME=excel_data