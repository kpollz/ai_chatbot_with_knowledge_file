# ============================================
# RAG Application Configuration
# ============================================
# Copy this file to .env and fill in your values

# ---- LLM Configuration ----
# Provider: "openai", "gemini", "ollama", or "custom"
LLM_PROVIDER=gemini

# Model name (provider-specific):
# - Gemini: gemini-1.5-flash, gemini-1.5-pro, gemini-pro
# - OpenAI: gpt-4o-mini, gpt-4o, gpt-3.5-turbo
# - Ollama: llama2, mistral, codellama
LLM_MODEL=gemini-1.5-flash

# Temperature (0 = deterministic, 1 = creative)
LLM_TEMPERATURE=0

# ---- API Keys (set the one for your provider) ----
# For OpenAI/ChatGPT
OPENAI_API_KEY=your-openai-api-key-here

# For Google Gemini (get from https://aistudio.google.com/apikey)
GOOGLE_API_KEY=your-google-api-key-here

# For Custom Company LLM (OpenAI-compatible API)
# CUSTOM_LLM_API_KEY=your-custom-api-key-here
# CUSTOM_LLM_BASE_URL=https://your-company-llm-api.com/v1

# For Ollama (local models)
# OLLAMA_BASE_URL=http://localhost:11434

# ---- Embedding Configuration ----
EMBED_MODEL=all-MiniLM-L6-v2

# ---- Vector Store Configuration ----
# Vector store provider: "faiss" or "chroma"
VECTOR_STORE_PROVIDER=faiss

# Persist directory for the vector store
PERSIST_DIR=./index/faiss
DATA_DIR=./data/raw
TOP_K=4
