# ============================================
# Chatbot Configuration
# ============================================

# ---- Issue API (Sub-project 2) ----
ISSUE_API_URL=http://localhost:8000

# ---- LLM Configuration ----
LLM_PROVIDER=company
LLM_MODEL=Gauss2.3
LLM_TEMPERATURE=0

# ---- Company LLM Configuration ----
COMPANY_LLM_API_KEY=your-company-api-key-here
COMPANY_LLM_MODEL_ID=your-model-id
COMPANY_LLM_MODEL_URL=https://mycompany.com/api/v1/run/session_id

# ---- Context Window ----
CONTEXT_WINDOW_LIMIT=128000
CONTEXT_WARN_THRESHOLD=100000
