# Gauss OpenAI-Compatible Proxy — Environment Variables

# Proxy Server
PROXY_HOST=0.0.0.0
PROXY_PORT=9000

# Company LLM Authentication (required)
COMPANY_LLM_API_KEY=your-api-key-here

# Override model-id / model-url for ALL models (optional)
# If set, these override the COMPANY_MODELS registry in config.py
# COMPANY_LLM_MODEL_ID=your-model-id
# COMPANY_LLM_MODEL_URL=https://mycompany.com/api/v1/run/session_id

# Defaults
DEFAULT_TEMPERATURE=0
DEFAULT_TOP_P=0.95
REQUEST_TIMEOUT=60
SSL_VERIFY=false

# Logging: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
