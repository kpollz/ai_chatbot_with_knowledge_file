# ============================================
# Chatbot Configuration
# ============================================

# ---- Issue API (Sub-project 2) ----
ISSUE_API_URL=http://localhost:8000

# ---- LLM Configuration ----
LLM_PROVIDER=company
LLM_MODEL=Gauss2.3
LLM_TEMPERATURE=0

# ---- Company LLM Configuration ----
COMPANY_LLM_API_KEY=your-company-api-key-here
COMPANY_LLM_MODEL_ID=your-model-id
COMPANY_LLM_MODEL_URL=https://mycompany.com/api/v1/run/session_id

# ---- Context Window ----
CONTEXT_WINDOW_LIMIT=128000
CONTEXT_WARN_THRESHOLD=100000

# ---- Langfuse Tracing (v4) ----
# Langfuse SDK v4 reads these env vars automatically
# Get your keys from: https://cloud.langfuse.com or your self-hosted instance
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com  # EU region
# LANGFUSE_HOST=https://us.cloud.langfuse.com  # US region
# LANGFUSE_DEBUG=False  # Enable debug logging
